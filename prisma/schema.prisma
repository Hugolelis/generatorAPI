generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model ShortenedUrl {
  id          Int      @id @default(autoincrement())
  shortCode   String   @unique
  originalUrl String
  shortUrl    String   @unique
  createdAt   DateTime @default(now())

  @@map("shortened_urls") 
}
